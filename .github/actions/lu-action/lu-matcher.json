{
  "problemMatcher": [
    {
      "owner": "lu-lint",
      "pattern": [
        {
          "regexp": "^\\s*(.+?):(\\d+):\\s+(error|warning)\\s+(LU-[A-Z]\\d{3})\\s+\\[.+?\\]\\s+(.+)$",
          "file": 1,
          "line": 2,
          "severity": 3,
          "code": 4,
          "message": 5
        }
      ]
    }
  ]
}
