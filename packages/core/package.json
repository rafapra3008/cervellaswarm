{
  "name": "@cervellaswarm/core",
  "version": "1.0.0-alpha.2",
  "description": "Core utilities for CervellaSwarm - shared between CLI and MCP Server",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    },
    "./config": {
      "import": "./dist/config/index.js",
      "types": "./dist/config/index.d.ts"
    },
    "./workers": {
      "import": "./dist/workers/index.js",
      "types": "./dist/workers/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "node --test test/*.test.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "keywords": [
    "cervellaswarm",
    "ai",
    "agents",
    "anthropic",
    "claude"
  ],
  "author": "Rafa & Cervella",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rafapra3008/CervellaSwarm.git",
    "directory": "packages/core"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "conf": "^15.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0"
  }
}
