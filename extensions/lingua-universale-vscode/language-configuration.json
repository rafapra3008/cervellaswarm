{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(type|agent|protocol|when|properties|requires|ensures).*:\\s*(#.*)?$"
  },
  "wordPattern": "[A-Za-z_][A-Za-z0-9_]*",
  "folding": {
    "markers": {
      "start": "^\\s*(agent|protocol|type|when|properties)\\b.*:\\s*$",
      "end": "^\\s*$"
    }
  }
}
