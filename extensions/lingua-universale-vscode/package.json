{
  "name": "lingua-universale",
  "displayName": "Lingua Universale",
  "description": "Full language support for Lingua Universale (.lu files): syntax highlighting, diagnostics, hover, completion, and go-to-definition - the first language designed for AI agents",
  "version": "0.2.0",
  "publisher": "cervellaswarm",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/rafapra3008/cervellaswarm"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "keywords": [
    "lingua-universale",
    "lu",
    "ai",
    "agents",
    "protocols",
    "formal-verification",
    "cervellaswarm",
    "lsp"
  ],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:lingua-universale"
  ],
  "contributes": {
    "languages": [
      {
        "id": "lingua-universale",
        "aliases": [
          "Lingua Universale",
          "LU",
          "lu"
        ],
        "extensions": [
          ".lu"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icon.png",
          "dark": "./icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "lingua-universale",
        "scopeName": "source.lu",
        "path": "./syntaxes/lingua-universale.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Lingua Universale",
      "properties": {
        "lingua-universale.luPath": {
          "type": "string",
          "default": "lu",
          "description": "Path to the 'lu' command. Set this if 'lu' is not on your PATH."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^3.0.0"
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  }
}
