#!/bin/bash
# =================================================================
# PRE-COMMIT HOOK - CervellaSwarm
# =================================================================
# BLOCCA il commit se:
# 1. File superano limiti di righe
# 2. Naming convention non rispettate
# =================================================================

# NOTA: NON usare "set -e" perche' ((VAR++)) con VAR=0 ritorna exit 1!

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

ERRORS=0
WARNINGS=0

echo ""
echo "=================================================="
echo "  PRE-COMMIT CHECK"
echo "=================================================="

# =================================================================
# 1. VERIFICA LIMITI RIGHE (BLOCCANTE)
# =================================================================

check_line_limit() {
    local file="$1"
    local limit="$2"
    local name="$3"

    if [ -f "$file" ]; then
        lines=$(wc -l < "$file" | tr -d ' ')
        if [ "$lines" -gt "$limit" ]; then
            echo -e "${RED}ERRORE:${NC} $name ha $lines righe (limite: $limit)"
            echo "        File: $file"
            echo "        AZIONE: Archivia contenuto vecchio!"
            ((ERRORS++))
        elif [ "$lines" -gt $((limit * 9 / 10)) ]; then
            echo -e "${YELLOW}WARNING:${NC} $name ha $lines righe (90% del limite $limit)"
            ((WARNINGS++))
        fi
    fi
}

# Ottieni file staged (usato in tutti i check successivi)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

echo ""
echo ">> Verificando limiti righe..."

# PROMPT_RIPRESA (max 250 - aggiornato S452 per 1M context era)
# Solo file STAGED (non bloccare commit per file di altre sessioni)
for pr in .sncp/progetti/*/PROMPT_RIPRESA_*.md; do
    if [ -f "$pr" ]; then
        if echo "$STAGED_FILES" | grep -q "$(echo "$pr" | sed 's|^\./||')" 2>/dev/null; then
            check_line_limit "$pr" 250 "$(basename "$pr")"
        fi
    fi
done

# SNCP 5.0 (S357): oggi.md e stato.md eliminati. Solo PROMPT_RIPRESA.

# =================================================================
# 2. VERIFICA NAMING CONVENTION (WARNING + BLOCCANTE)
# =================================================================

echo ""
echo ">> Verificando naming convention..."

for file in $STAGED_FILES; do
    filename=$(basename "$file")

    # .sncp/ files naming check
    if [[ "$file" == .sncp/* ]]; then
        # PROMPT_RIPRESA deve avere nome progetto o braccio
        if [[ "$filename" == PROMPT_RIPRESA_* ]]; then
            # Eccezione: PROMPT_RIPRESA_MASTER.md è il file panoramica
            if [[ "$filename" == "PROMPT_RIPRESA_MASTER.md" ]]; then
                : # OK - file master
            # Accetta: PROMPT_RIPRESA_{nome}.md dove nome può avere trattini (es: pms-core)
            elif [[ ! "$filename" =~ ^PROMPT_RIPRESA_[a-z][a-z0-9_-]*\.md$ ]]; then
                echo -e "${RED}ERRORE:${NC} PROMPT_RIPRESA naming errato: $filename"
                echo "        Deve essere: PROMPT_RIPRESA_{progetto}.md o PROMPT_RIPRESA_{braccio}.md"
                ((ERRORS++))
            fi
        fi

        # Handoff deve avere numero sessione
        if [[ "$filename" == HANDOFF_* ]]; then
            if [[ ! "$filename" =~ ^HANDOFF_[0-9]+\.md$ ]]; then
                echo -e "${YELLOW}WARNING:${NC} HANDOFF naming: $filename (preferito: HANDOFF_NNN.md)"
                ((WARNINGS++))
            fi
        fi
    fi

    # reports/ files - preferisci data nel nome
    if [[ "$file" == reports/* ]] && [[ "$file" != reports/archive/* ]]; then
        if [[ "$filename" =~ \.md$ ]] || [[ "$filename" =~ \.json$ ]]; then
            # Warning se non ha data nel nome (non bloccante)
            if [[ ! "$filename" =~ [0-9]{8} ]] && [[ ! "$filename" =~ [0-9]{4}-[0-9]{2}-[0-9]{2} ]]; then
                echo -e "${YELLOW}HINT:${NC} Report senza data nel nome: $filename"
                echo "        Preferito: {tipo}_{YYYYMMDD}.{ext}"
            fi
        fi
    fi
done

# =================================================================
# 3. VERIFICA DOCS SYNC (Sessione 250 - Docs Sync System)
# =================================================================

echo ""
echo ">> Verificando docs sync..."

# SNCP 4.0: docs sync tramite PROMPT_RIPRESA (non piu stato.md)
CODE_CHANGED=$(echo "$STAGED_FILES" | grep -E "^packages/|^src/|^scripts/" || true)

if [ -n "$CODE_CHANGED" ]; then
    RIPRESA_STAGED=$(echo "$STAGED_FILES" | grep "PROMPT_RIPRESA" || true)
    if [ -n "$RIPRESA_STAGED" ]; then
        echo -e "${GREEN}OK:${NC} PROMPT_RIPRESA incluso nel commit"
    fi
fi

# =================================================================
# 4. VERIFICA COMPLIANCE MARKER (WARNING per ora)
# =================================================================

echo ""
echo ">> Verificando compliance marker..."

for file in $STAGED_FILES; do
    # Solo report in .sncp/progetti/*/reports/
    if [[ "$file" == .sncp/progetti/*/reports/*.md ]]; then
        if [ -f "$file" ]; then
            # Verifica presenza marker COSTITUZIONE-APPLIED
            if ! grep -q "COSTITUZIONE-APPLIED:" "$file" 2>/dev/null; then
                echo -e "${YELLOW}WARNING:${NC} Report senza marker COSTITUZIONE-APPLIED: $(basename "$file")"
                echo "        Agenti devono includere: COSTITUZIONE-APPLIED: SI/NO"
                ((WARNINGS++))
            fi
        fi
    fi
done

# =================================================================
# 5. LU FORMAT + LINT CHECK (S449 - Sprint 2)
# =================================================================

echo ""
echo ">> Verificando .lu files..."

LU_STAGED=$(echo "$STAGED_FILES" | grep '\.lu$' || true)

if [ -n "$LU_STAGED" ]; then
    # Check if lu CLI is available
    if command -v lu &>/dev/null; then
        # Format check (exit 1 = files need reformatting)
        LU_FMT_FAILED=0
        for lufile in $LU_STAGED; do
            if [ -f "$lufile" ]; then
                if ! lu fmt --check "$lufile" &>/dev/null; then
                    echo -e "${RED}ERRORE:${NC} $lufile non formattato (esegui: lu fmt $lufile)"
                    LU_FMT_FAILED=1
                fi
            fi
        done
        if [ "$LU_FMT_FAILED" -eq 1 ]; then
            ((ERRORS++))
        fi

        # Lint check (exit 1 = findings)
        LU_LINT_FAILED=0
        for lufile in $LU_STAGED; do
            if [ -f "$lufile" ]; then
                LINT_OUTPUT=$(lu lint "$lufile" 2>&1)
                LINT_RC=$?
                if [ "$LINT_RC" -ne 0 ]; then
                    echo -e "${YELLOW}WARNING:${NC} lu lint findings in $lufile"
                    echo "$LINT_OUTPUT" | head -5
                    LU_LINT_FAILED=1
                fi
            fi
        done
        if [ "$LU_LINT_FAILED" -eq 1 ]; then
            ((WARNINGS++))
        fi
    else
        echo -e "${YELLOW}HINT:${NC} lu CLI non trovato, skip format/lint check"
        echo "        Installa: pip install cervellaswarm-lingua-universale"
    fi
else
    echo -e "${GREEN}OK:${NC} Nessun file .lu staged"
fi

# =================================================================
# RISULTATO
# =================================================================

echo ""
echo "=================================================="

if [ "$ERRORS" -gt 0 ]; then
    echo -e "${RED}COMMIT BLOCCATO!${NC}"
    echo "  Errori: $ERRORS"
    echo "  Warning: $WARNINGS"
    echo ""
    echo "Risolvi gli errori e riprova."
    echo "=================================================="
    exit 1
fi

if [ "$WARNINGS" -gt 0 ]; then
    echo -e "${YELLOW}COMMIT OK (con $WARNINGS warning)${NC}"
else
    echo -e "${GREEN}COMMIT OK${NC}"
fi
echo "=================================================="
echo ""

exit 0
